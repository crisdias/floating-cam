<Window x:Class="FloatingCam.FramingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajustar enquadramento"
        Icon="Assets/app.ico"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#FF2B2B2B">
    <StackPanel Margin="16">
        <TextBlock Foreground="#FFEAEAEA" TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="Você vê o sinal completo da webcam. A moldura mostra o que vai aparecer na caixa flutuante — arraste-a para escolher a região e use o zoom para aproximar."/>

        <Border HorizontalAlignment="Center" BorderBrush="#FF555555" BorderThickness="1">
            <Canvas x:Name="PreviewCanvas" Background="Black" ClipToBounds="True"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    Cursor="SizeAll">
                <Image x:Name="PreviewImage" Canvas.Left="0" Canvas.Top="0"/>
                <!-- Dark mask outside the guide (geometry set in code) -->
                <Path x:Name="DimPath" Fill="#99000000" IsHitTestVisible="False"/>
                <!-- Crop guide rectangle -->
                <Rectangle x:Name="CropRect" Stroke="White" StrokeThickness="2"
                           StrokeDashArray="4 3" IsHitTestVisible="False"/>
            </Canvas>
        </Border>

        <DockPanel Margin="0,16,0,0">
            <TextBlock Text="Zoom" Foreground="#FFEAEAEA" VerticalAlignment="Center"
                       Margin="0,0,8,0" DockPanel.Dock="Left"/>
            <TextBlock x:Name="ZoomLabel" Text="1.0x" Foreground="#FFEAEAEA" Width="44"
                       TextAlignment="Right" VerticalAlignment="Center"
                       Margin="8,0,0,0" DockPanel.Dock="Right"/>
            <Slider x:Name="ZoomSlider" Minimum="1" Maximum="4" Value="1"
                    SmallChange="0.05" LargeChange="0.25" VerticalAlignment="Center"/>
        </DockPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="ResetButton" Content="Reset" Padding="12,4" Margin="0,0,8,0"/>
            <Button x:Name="CloseButton" Content="Fechar" Padding="12,4"/>
        </StackPanel>
    </StackPanel>
</Window>
